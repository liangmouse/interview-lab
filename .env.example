# 本地开发默认配置
NODE_ENV=development
NEXT_PUBLIC_DEBUG=true

# =========================
# 必填：基础服务
# =========================

# Supabase
# 获取位置：Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# 可选：如果项目改用了 publishable key，可填这个兼容键名
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_publishable_key

# LiveKit（语音面试必填）
LIVEKIT_URL=wss://your-livekit-host.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# 火山引擎 BigASR 2.0（默认语音识别 STT）
VOLCENGINE_STT_APP_ID=your_volcengine_stt_app_id
VOLCENGINE_STT_ACCESS_TOKEN=your_volcengine_stt_access_token
# 默认会回退到 volc.bigasr.sauc.duration，如有私有资源包可覆盖
VOLCENGINE_STT_RESOURCE_ID=volc.bigasr.sauc.duration
# 可选：控制台热词表 ID
# VOLCENGINE_STT_BOOSTING_TABLE_ID=your_boosting_table_id

# Deepgram（备用 STT Provider，非默认）
# DEEPGRAM_API_KEY=your_deepgram_api_key

# =========================
# 必填：默认 AI 配置
# =========================

# OpenRouter（默认 LLM / Embedding 提供方）
OPEN_ROUTER_API_KEY=your_openrouter_api_key
OPEN_ROUTER_MODEL=
OPEN_ROUTER_EMBEDDING_MODEL=openai/text-embedding-3-large

# 火山引擎豆包 TTS（语音输出）
# 控制台申请：https://console.volcengine.com/speech/service/10007
VOLCENGINE_TTS_APP_ID=your_volcengine_tts_app_id
VOLCENGINE_TTS_ACCESS_TOKEN=your_volcengine_tts_access_token
# 可选：默认 volcano_tts，有私有资源包时覆盖
# VOLCENGINE_TTS_CLUSTER=volcano_tts
# 可选：默认 BV700_streaming，完整音色列表见 https://www.volcengine.com/docs/6561/1108211
# VOLCENGINE_TTS_VOICE=BV700_streaming

# 仅当你需要直连 Gemini LLM / Embedding 时再配置
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-3.0-flash
# GEMINI_EMBEDDING_MODEL=text-embedding-004

# Web 搜索能力（按需启用）
# EXA_API_KEY=your_exa_api_key

# =========================
# 可选：Langfuse 追踪
# =========================
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
# 自托管或 EU 区域时再配置；默认官方云
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# 显式关闭可设置为 false / 0
# LANGFUSE_ENABLED=true
