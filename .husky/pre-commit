#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# 运行 lint-staged (格式化和 lint)
echo "📝 Running lint and format..."
npx lint-staged

if [ $? -ne 0 ]; then
  echo "❌ Lint/format failed!"
  exit 1
fi

# 运行单元测试
echo "🧪 Running unit tests..."
pnpm test

if [ $? -ne 0 ]; then
  echo "❌ Unit tests failed! Please fix them before committing."
  exit 1
fi

# 运行构建，确保提交前可以成功构建
echo "🏗️ Running build..."
pnpm build

if [ $? -ne 0 ]; then
  echo "❌ Build failed! Please fix build errors before committing."
  exit 1
fi

echo "✅ Pre-commit checks passed!"
