{
  "name": "interviewclaw",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "node scripts/dev-with-agent.mjs",
    "dev:web": "pnpm --filter @interviewclaw/web dev",
    "dev:gateway": "pnpm --filter @interviewclaw/gateway dev",
    "dev:scheduler": "pnpm --filter @interviewclaw/scheduler dev",
    "dev:agent": "pnpm --filter @interviewclaw/livekit-agent dev",
    "dev:turbo": "turbo run dev --parallel --filter=@interviewclaw/web --filter=@interviewclaw/livekit-agent",
    "build": "turbo run build && rm -rf .next && cp -R apps/web/.next .next",
    "build:web": "pnpm --filter @interviewclaw/web build",
    "build:agent": "pnpm --filter @interviewclaw/livekit-agent build",
    "start": "pnpm --filter @interviewclaw/web start",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "prepare": "husky install",
    "commit": "git-cz",
    "test": "vitest run",
    "test:packages": "vitest run packages",
    "agent:dev": "pnpm --filter @interviewclaw/livekit-agent dev",
    "agent:kill": "pnpm --filter @interviewclaw/livekit-agent kill",
    "download-files": "pnpm --filter @interviewclaw/livekit-agent download-files"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "dependencies": {
    "@ai-sdk/react": "^2.0.48",
    "@langchain/community": "^1.0.0",
    "@langchain/core": "^1.0.2",
    "@langchain/openai": "^1.1.3",
    "@livekit/agents": "^1.0.24",
    "@livekit/agents-plugin-deepgram": "^1.0.24",
    "@livekit/agents-plugin-livekit": "^1.0.30",
    "@livekit/agents-plugin-openai": "^1.0.24",
    "@livekit/agents-plugin-silero": "^1.0.27",
    "@livekit/rtc-node": "^0.13.22",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.48.1",
    "@types/lodash": "^4.17.20",
    "@vercel/analytics": "^1.5.0",
    "ai": "5.0.45",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "framer-motion": "12.0.0-alpha.0",
    "langchain": "^1.0.2",
    "livekit-client": "^2.16.0",
    "livekit-server-sdk": "^2.14.2",
    "lodash": "^4.17.21",
    "lucide-react": "^0.525.0",
    "next": "15.3.8",
    "next-intl": "^4.5.5",
    "postcss": "^8.5.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^14.3.8",
    "react-easy-crop": "^5.5.6",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.6",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "turbo": "^2.5.8",
    "unpdf": "^1.4.0",
    "uuid": "^11.1.0",
    "zod": "^4.1.8",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/dotenv": "^8.2.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vitejs/plugin-react": "^5.1.2",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "15.3.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "husky": "^8.0.3",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "tailwindcss": "^4.1.16",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.15"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "sharp": "0.34.4"
    }
  }
}
